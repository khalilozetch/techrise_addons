<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- =============================================================== -->
    <!-- ACCOUNTING SOFTWARE UAE — Product landing page                  -->
    <!-- Paid-ads & SEO target: "accounting software uae", "odoo         -->
    <!-- accounting", "vat-ready accounting software dubai".             -->
    <!-- =============================================================== -->
    <template id="accounting_software_page" name="Accounting Software UAE - Techrise">
        <t t-call="website.layout">
            <t t-set="additional_title">Accounting Software UAE — VAT, Corporate Tax &amp; E-invoicing 2026 Ready</t>
