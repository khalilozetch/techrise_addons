<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- HOMEPAGE TEMPLATE                                             -->
    <!-- ============================================================ -->
    <template id="techrise_homepage" inherit_id="website.homepage" name="Techrise Homepage">
        <xpath expr="//div[@id='wrap']" position="replace">
            <div id="wrap">

                <!-- ======== HERO SECTION WITH VIDEO BACKGROUND ========
                     Mobile: CSS background image only (no video) — avoids ~9 MB payload
                     Desktop: iframe is injected by JS after page load to keep LCP fast. -->
                <section class="tr-hero">
                    <div class="tr-hero-video-bg"
                         data-vimeo-src="https://player.vimeo.com/video/1138384954?autoplay=1&amp;muted=1&amp;autopause=0&amp;controls=0&amp;loop=1&amp;background=1"
                         aria-hidden="true">
                        <!-- iframe injected after page load, only on viewports >= 992px -->
                    </div>
                    <div class="tr-hero-overlay"/>
                    <div class="container">
                        <div class="tr-hero-content text-center">
                            <h1>
                                Odoo Partner in Abu Dhabi for
                                <span class="tr-text-gold">Digital Transformation</span>
                                Across the UAE
                            </h1>
                            <p class="tr-hero-description">
                                Techrise delivers Odoo ERP implementation, customization, accounting,
                                CRM, HR, and inventory management for businesses in Abu Dhabi, Dubai,
                                and across the UAE — from small companies to enterprise rollouts.
                            </p>
                            <div class="tr-hero-btns">
                                <a href="/contact" class="tr-btn tr-btn-primary" data-tr-event="consultation_cta_click">
                                    Get a Free Odoo Consultation
                                </a>
                                <a href="/services" class="tr-btn tr-btn-outline">
                                    Explore Our Services
                                </a>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- ======== STATS COUNTER ======== -->
                <section class="tr-stats">
                    <div class="container">
                        <div class="tr-stats-inner">
                            <div class="tr-stat-item">
                                <div class="tr-stat-number">
                                    <span class="tr-counter" data-target="100">0</span>
                                    <span class="tr-stat-suffix">+</span>
                                </div>
                                <div class="tr-stat-label">Projects Delivered</div>
                            </div>
                            <div class="tr-stat-item">
                                <div class="tr-stat-number">
                                    <span class="tr-counter" data-target="100">0</span>
                                    <span class="tr-stat-suffix">+</span>
                                </div>
                                <div class="tr-stat-label">Happy Clients</div>
                            </div>
                            <div class="tr-stat-item">
                                <div class="tr-stat-number">
                                    <span class="tr-counter" data-target="15">0</span>
                                    <span class="tr-stat-suffix">+</span>
                                </div>
                                <div class="tr-stat-label">Countries Served</div>
                            </div>
                            <div class="tr-stat-item">
                                <div class="tr-stat-number">
                                    <span class="tr-counter" data-target="30">0</span>
                                    <span class="tr-stat-suffix">+</span>
                                </div>
                                <div class="tr-stat-label">Expert Consultants</div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- ======== ABOUT SECTION (White) ======== -->
                <section class="tr-section tr-section-white" id="about-home">
                    <div class="container">
                        <div class="row align-items-center">
                            <div class="col-lg-6 mb-4 mb-lg-0">
                                <picture>
                                    <source media="(max-width: 991.98px)" type="image/webp"
                                            srcset="/techrise_website/static/src/img/bg/about-team-erp-mobile.webp"/>
                                    <source media="(max-width: 991.98px)" type="image/jpeg"
                                            srcset="/techrise_website/static/src/img/bg/about-team-erp-mobile.jpg"/>
                                    <source type="image/webp"
                                            srcset="/techrise_website/static/src/img/bg/about-team-erp.webp"/>
                                    <img src="/techrise_website/static/src/img/bg/about-team-erp.jpg"
                                         alt="Techrise team delivering Odoo ERP and digital transformation for UAE businesses"
                                         class="img-fluid rounded-4 shadow-lg"
                                         width="640" height="640" loading="lazy" decoding="async"
                                         style="width: 100%; height: auto; object-fit: cover;"/>
                                </picture>
                            </div>
                            <div class="col-lg-6">
                                <h2 class="tr-section-title tr-animate">
                                    About <span class="tr-text-gold">Techrise</span>
                                </h2>
                                <div class="tr-gold-line" style="margin-left: 0;"/>
                                <p class="tr-animate tr-animate-delay-1" style="color: #64748B; line-height: 1.8; margin-bottom: 1.5rem;">
                                    Techrise is a specialized entity providing comprehensive technical and
                                    administrative solutions. As an accredited Odoo partner, we support companies
                                    in rebuilding their operational processes through modern digital methodology
                                    based on organization, accuracy, and sustainability.
                                </p>
                                <p class="tr-animate tr-animate-delay-2" style="color: #64748B; line-height: 1.8;">
                                    We focus on transforming operational complexity into intelligent,
                                    interconnected systems that enable departments to work within a unified
                                    framework, ensuring data clarity and improved performance efficiency.
                                </p>
                                <a href="/about" class="tr-btn tr-btn-blue mt-3 tr-animate tr-animate-delay-3"
                                   aria-label="Learn More About Techrise">
                                    Learn More About Techrise <i class="fa fa-arrow-right" aria-hidden="true"/>
                                </a>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- ======== SERVICES SECTION ======== -->
                <section class="tr-section tr-section-light" id="services">
                    <div class="container">
                        <div class="text-center mb-5">
                            <h2 class="tr-section-title tr-animate">Our Services</h2>
                            <div class="tr-gold-line"/>
                            <p class="tr-section-subtitle tr-animate tr-animate-delay-1">
                                Comprehensive digital solutions tailored to your business needs.
                                From ERP systems to mobile apps, we've got you covered.
                            </p>
                        </div>
                        <div class="tr-services-grid">
                            <div class="tr-service-card tr-animate">
                                <div class="tr-service-icon-img">
                                    <img src="/techrise_website/static/src/img/services-erp.svg" alt="ERP Systems" width="64" height="64"/>
                                </div>
                                <h3>ERP System Design (Odoo)</h3>
                                <p>
                                    Comprehensive ERP systems tailored to your business -
                                    Accounting, Sales, Inventory, HR, and Procurement in one unified platform.
                                </p>
                            </div>
                            <div class="tr-service-card tr-animate tr-animate-delay-1">
                                <div class="tr-service-icon-img">
                                    <img src="/techrise_website/static/src/img/services-web.svg" alt="Website Development" width="64" height="64"/>
                                </div>
                                <h3>Website Design &amp; Development</h3>
                                <p>
                                    Professional websites with strong visual identity,
                                    responsive across all devices with fast loading and great UX.
                                </p>
                            </div>
                            <div class="tr-service-card tr-animate tr-animate-delay-2">
                                <div class="tr-service-icon-img">
                                    <img src="/techrise_website/static/src/img/services-mobile.svg" alt="Mobile Apps" width="64" height="64"/>
                                </div>
                                <h3>Mobile App Development</h3>
                                <p>
                                    Android and iOS apps with high performance, security,
                                    and seamless integration with Odoo or any other platforms.
                                </p>
                            </div>
                            <div class="tr-service-card tr-animate">
                                <div class="tr-service-icon">
                                    <i class="fa fa-plug"/>
                                </div>
                                <h3>System Integration</h3>
                                <p>
                                    Integration between Odoo and other software, government authorities,
                                    and official platforms for unified data and faster operations.
                                </p>
                            </div>
                            <div class="tr-service-card tr-animate tr-animate-delay-1">
                                <div class="tr-service-icon">
                                    <i class="fa fa-calculator"/>
                                </div>
                                <h3>Accounting &amp; Tax Services</h3>
                                <p>
                                    VAT filing, Corporate Tax returns, accounting organization,
                                    and establishment of qualified accounting teams.
                                </p>
                            </div>
                            <div class="tr-service-card tr-animate tr-animate-delay-2">
                                <div class="tr-service-icon">
                                    <i class="fa fa-bullhorn"/>
                                </div>
                                <h3>Branding &amp; Marketing</h3>
                                <p>
                                    Complete brand identity, marketing strategies, smart campaigns
                                    integrated with operational systems for measurable results.
                                </p>
                            </div>
                        </div>
                        <div class="text-center mt-4">
                            <a href="/services" class="tr-btn tr-btn-dark tr-animate">
                                View All Services <i class="fa fa-arrow-right"/>
                            </a>
                        </div>
                    </div>
                </section>

                <!-- ======== WHY CHOOSE US (White) ======== -->
                <section class="tr-section tr-section-white" id="why-us">
                    <div class="container">
                        <div class="text-center mb-5">
                            <h2 class="tr-section-title tr-animate">
                                Why Choose <span class="tr-text-gold">Techrise</span>?
                            </h2>
                            <div class="tr-gold-line"/>
                            <p class="tr-section-subtitle tr-animate tr-animate-delay-1">
                                A deep understanding of organizational operations, scientific digital principles,
                                and scalable solutions built for growth.
                            </p>
                        </div>
                        <div class="row">
                            <div class="col-lg-3 col-md-6 mb-4">
                                <div class="tr-why-card tr-animate">
                                    <div class="tr-why-icon">
                                        <i class="fa fa-search"/>
                                    </div>
                                    <h3>Deep Business Analysis</h3>
                                    <p>We analyze your work environment accurately to provide solutions that reflect operational reality.</p>
                                </div>
                            </div>
                            <div class="col-lg-3 col-md-6 mb-4">
                                <div class="tr-why-card tr-animate tr-animate-delay-1">
                                    <div class="tr-why-icon">
                                        <i class="fa fa-shield"/>
                                    </div>
                                    <h3>Proven Solutions</h3>
                                    <p>Tested software and technical solutions trusted by leading companies with reliable high-quality results.</p>
                                </div>
                            </div>
                            <div class="col-lg-3 col-md-6 mb-4">
                                <div class="tr-why-card tr-animate tr-animate-delay-2">
                                    <div class="tr-why-icon">
                                        <i class="fa fa-users"/>
                                    </div>
                                    <h3>Expert Team</h3>
                                    <p>Specialists in information systems, technical intelligence, and software development with precision and usability.</p>
                                </div>
                            </div>
                            <div class="col-lg-3 col-md-6 mb-4">
                                <div class="tr-why-card tr-animate tr-animate-delay-3">
                                    <div class="tr-why-icon">
                                        <i class="fa fa-expand"/>
                                    </div>
                                    <h3>Scalable Solutions</h3>
                                    <p>Solutions adaptable to technological changes and growth requirements for sustainable digital transformation.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- ======== OUR PROCESS ======== -->
                <section class="tr-section tr-section-light" id="process">
                    <div class="container">
                        <div class="text-center mb-5">
                            <h2 class="tr-section-title tr-animate">How We Work</h2>
                            <div class="tr-gold-line"/>
                            <p class="tr-section-subtitle tr-animate tr-animate-delay-1">
                                Our proven methodology ensures successful project delivery every time.
                            </p>
                        </div>
                        <div class="tr-process-grid">
                            <div class="tr-process-card tr-animate">
                                <div class="tr-process-number">1</div>
                                <h3>Analysis</h3>
                                <p>Comprehensive analysis of the current work environment and precise evaluation of operational workflows.</p>
                            </div>
                            <div class="tr-process-card tr-animate tr-animate-delay-1">
                                <div class="tr-process-number">2</div>
                                <h3>Design &amp; Plan</h3>
                                <p>Design integrated technical solutions balancing operational requirements with strategic objectives.</p>
                            </div>
                            <div class="tr-process-card tr-animate tr-animate-delay-2">
                                <div class="tr-process-number">3</div>
                                <h3>Implement</h3>
                                <p>System implementation according to clear standards with data migration and rigorous testing.</p>
                            </div>
                            <div class="tr-process-card tr-animate tr-animate-delay-3">
                                <div class="tr-process-number">4</div>
                                <h3>Support &amp; Grow</h3>
                                <p>Ongoing support and development ensuring system stability and ability to adapt to business growth.</p>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- ======== INDUSTRIES (Dark Section) ======== -->
                <section class="tr-section tr-section-dark" id="industries">
                    <div class="container">
                        <div class="text-center mb-5">
                            <h2 class="tr-section-title tr-section-title-light tr-animate">
                                ERP for Construction, Healthcare, Retail &amp; More in the UAE
                            </h2>
                            <div class="tr-gold-line"/>
                            <p class="tr-section-subtitle tr-section-subtitle-light tr-animate tr-animate-delay-1">
                                Flexible and scalable Odoo ERP solutions tailored for the leading
                                industries across Abu Dhabi, Dubai, and the wider UAE market.
                            </p>
                        </div>
                        <div class="tr-industries-grid">
                            <a href="/erp-for-healthcare-uae" class="tr-industry-card tr-animate" style="color: inherit; text-decoration: none;">
                                <div class="tr-industry-icon"><i class="fa fa-heartbeat"/></div>
                                <h3>ERP for Healthcare UAE</h3>
                                <p>Patient management, billing, pharmacy, and compliance</p>
                            </a>
                            <div class="tr-industry-card tr-animate tr-animate-delay-1">
                                <div class="tr-industry-icon"><i class="fa fa-building"/></div>
                                <h3>Real Estate</h3>
                                <p>Property management, contracts, CRM, and accounting</p>
                            </div>
                            <a href="/erp-for-construction-uae" class="tr-industry-card tr-animate tr-animate-delay-2" style="color: inherit; text-decoration: none;">
                                <div class="tr-industry-icon"><i class="fa fa-wrench"/></div>
                                <h3>ERP for Construction UAE</h3>
                                <p>Project cost tracking, procurement, and resource planning</p>
                            </a>
                            <div class="tr-industry-card tr-animate tr-animate-delay-3">
                                <div class="tr-industry-icon"><i class="fa fa-medkit"/></div>
                                <h3>Pharmacies</h3>
                                <p>Inventory, prescriptions, POS, and supplier management</p>
                            </div>
                            <div class="tr-industry-card tr-animate">
                                <div class="tr-industry-icon"><i class="fa fa-futbol-o"/></div>
                                <h3>Sports Clubs</h3>
                                <p>Membership, scheduling, billing, and facility management</p>
                            </div>
                            <div class="tr-industry-card tr-animate tr-animate-delay-1">
                                <div class="tr-industry-icon"><i class="fa fa-handshake-o"/></div>
                                <h3>Cooperative Associations</h3>
                                <p>Member management, operations, and financial tracking</p>
                            </div>
                            <a href="/erp-for-retail-uae" class="tr-industry-card tr-animate tr-animate-delay-2" style="color: inherit; text-decoration: none;">
                                <div class="tr-industry-icon"><i class="fa fa-shopping-cart"/></div>
                                <h3>ERP for Retail UAE</h3>
                                <p>Point of sale, multi-branch, inventory, and omnichannel</p>
                            </a>
                            <div class="tr-industry-card tr-animate tr-animate-delay-3">
                                <div class="tr-industry-icon"><i class="fa fa-plane"/></div>
                                <h3>Travel &amp; Tourism</h3>
                                <p>Booking, CRM, invoicing, and partner management</p>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- ======== CTA SECTION ======== -->
                <section class="tr-cta-section">
                    <div class="container text-center">
                        <div class="tr-odoo-badge tr-animate">
                            <i class="fa fa-handshake-o" style="font-size: 1.5rem;"/>
                            <span>Official Odoo Partner</span>
                        </div>
                        <h2 class="tr-animate tr-animate-delay-1">
                            Ready to Transform Your Business?
                        </h2>
                        <p class="tr-animate tr-animate-delay-2">
                            We accompany our clients throughout all stages of digital transformation -
                            from consultation and planning, through implementation, to ongoing support.
                        </p>
                        <div class="tr-animate tr-animate-delay-3">
                            <a href="/contactus" class="tr-btn tr-btn-primary" style="margin-right: 12px;">
                                Get Started <i class="fa fa-arrow-right"/>
                            </a>
                            <a href="/services" class="tr-btn tr-btn-dark">
                                View Services <i class="fa fa-th-large"/>
                            </a>
                        </div>
                    </div>
                </section>

            </div>
        </xpath>
    </template>

</odoo>
