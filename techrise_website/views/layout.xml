<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- ADD NAVBAR CLASS VIA HEADER ATTRIBUTES                        -->
    <!-- ============================================================ -->
    <template id="techrise_header" inherit_id="website.layout" name="Techrise Header">
        <xpath expr="//header" position="attributes">
            <attribute name="class" add="tr-navbar" separator=" "/>
        </xpath>
    </template>



    <!-- ============================================================ -->
    <!-- FLOATING WHATSAPP BUTTON ON ALL PAGES                         -->
    <!-- ============================================================ -->
    <template id="techrise_whatsapp_button" inherit_id="website.layout" name="Techrise WhatsApp Button">
        <xpath expr="//div[@id='wrapwrap']" position="inside">
            <a href="https://wa.me/971585955064?text=Hello%20Techrise%2C%20I%27m%20interested%20in%20your%20services%20and%20would%20like%20to%20know%20more." target="_blank" class="tr-whatsapp-float" aria-label="Chat on WhatsApp" data-tr-event="whatsapp_chat_open">
                <i class="fa fa-whatsapp"/>
            </a>
        </xpath>
    </template>

    <!-- ============================================================ -->
    <!-- COOKIE CONSENT BANNER (Google Consent Mode V2 compatible)     -->
    <!-- ============================================================ -->
    <template id="techrise_cookie_banner" inherit_id="website.layout" name="Techrise Cookie Banner">
        <xpath expr="//div[@id='wrapwrap']" position="inside">
            <div id="tr-cookie-banner" class="tr-cookie-banner" role="dialog" aria-live="polite" aria-label="Cookie consent">
                <div class="tr-cookie-content">
                    <div class="tr-cookie-text">
                        <h5>
                            <i class="fa fa-shield"/>
                            <span class="tr-cookie-title-en">We value your privacy</span>
                            <span class="tr-cookie-title-ar">نحن نحترم خصوصيتك</span>
                        </h5>
                        <p class="tr-cookie-desc-en">
                            We use cookies to enhance your browsing experience, analyze site traffic, and personalize content.
                            By clicking "Accept All", you consent to our use of cookies.
                            See our <a href="/privacy-policy">Privacy Policy</a> for details.
                        </p>
                        <p class="tr-cookie-desc-ar">
                            نستخدم ملفات تعريف الارتباط (Cookies) لتحسين تجربتك وتحليل زيارات الموقع وتخصيص المحتوى.
                            بالنقر على "قبول الكل" فإنك توافق على استخدامنا لملفات تعريف الارتباط.
                            راجع <a href="/privacy-policy">سياسة الخصوصية</a> للمزيد.
                        </p>
                    </div>
                    <div class="tr-cookie-actions">
                        <button type="button" id="tr-cookie-reject" class="tr-cookie-btn tr-cookie-btn-secondary">
                            <span class="tr-cookie-btn-en">Reject All</span>
                            <span class="tr-cookie-btn-ar">رفض الكل</span>
                        </button>
                        <button type="button" id="tr-cookie-customize" class="tr-cookie-btn tr-cookie-btn-secondary">
                            <span class="tr-cookie-btn-en">Customize</span>
                            <span class="tr-cookie-btn-ar">تخصيص</span>
                        </button>
                        <button type="button" id="tr-cookie-accept" class="tr-cookie-btn tr-cookie-btn-primary">
                            <span class="tr-cookie-btn-en">Accept All</span>
                            <span class="tr-cookie-btn-ar">قبول الكل</span>
                        </button>
                    </div>
                </div>

                <!-- Preferences panel -->
                <div id="tr-cookie-preferences" class="tr-cookie-preferences" hidden="hidden">
                    <h6>
                        <span class="tr-cookie-title-en">Cookie Preferences</span>
                        <span class="tr-cookie-title-ar">تفضيلات ملفات تعريف الارتباط</span>
                    </h6>
                    <div class="tr-cookie-option">
                        <label>
                            <input type="checkbox" checked="checked" disabled="disabled"/>
                            <strong><span class="tr-cookie-btn-en">Essential</span><span class="tr-cookie-btn-ar">أساسية</span></strong>
                            <small><span class="tr-cookie-btn-en">Required for the site to function. Always on.</span><span class="tr-cookie-btn-ar">ضرورية لعمل الموقع. مفعّلة دائماً.</span></small>
                        </label>
                    </div>
                    <div class="tr-cookie-option">
                        <label>
                            <input type="checkbox" id="tr-cookie-analytics"/>
                            <strong><span class="tr-cookie-btn-en">Analytics</span><span class="tr-cookie-btn-ar">تحليلات</span></strong>
                            <small><span class="tr-cookie-btn-en">Help us understand how visitors use the site (Google Analytics).</span><span class="tr-cookie-btn-ar">تساعدنا على فهم كيفية استخدام الزوار للموقع (جوجل أنالتكس).</span></small>
                        </label>
                    </div>
                    <div class="tr-cookie-option">
                        <label>
                            <input type="checkbox" id="tr-cookie-ads"/>
                            <strong><span class="tr-cookie-btn-en">Advertising</span><span class="tr-cookie-btn-ar">إعلانات</span></strong>
                            <small><span class="tr-cookie-btn-en">Used to measure ad performance and personalize marketing (Google Ads).</span><span class="tr-cookie-btn-ar">لقياس أداء الإعلانات وتخصيص التسويق (جوجل آدز).</span></small>
                        </label>
                    </div>
                    <div class="tr-cookie-actions">
                        <button type="button" id="tr-cookie-save" class="tr-cookie-btn tr-cookie-btn-primary">
                            <span class="tr-cookie-btn-en">Save Preferences</span>
                            <span class="tr-cookie-btn-ar">حفظ التفضيلات</span>
                        </button>
                    </div>
                </div>
            </div>
        </xpath>
    </template>

    <!-- ============================================================ -->
    <!-- CUSTOM FOOTER - Replace default footer content                -->
    <!-- ============================================================ -->
    <template id="techrise_footer" inherit_id="website.footer_custom" name="Techrise Footer">
        <xpath expr="//div[@id='footer']" position="replace">
            <div id="footer" class="tr-footer" t-if="not no_footer">
                <div class="container">
                    <div class="row">
                        <!-- Company Info -->
                        <div class="col-lg-4 col-md-6 mb-4">
                            <img src="/techrise_website/static/src/img/logo.png"
                                 alt="Techrise" class="tr-footer-logo" width="160" height="45"/>
                            <p class="tr-footer-about">
                                Techrise - Your Partner in Organized Digital Transformation.
                                A specialized entity providing comprehensive technical and
                                administrative solutions as an accredited Odoo partner.
                            </p>
                            <div class="tr-social-links">
                                <a href="https://www.linkedin.com/company/108618958" target="_blank" rel="noopener" aria-label="LinkedIn"><i class="fa fa-linkedin"/></a>
                                <a href="https://www.facebook.com/techriseae" target="_blank" rel="noopener" aria-label="Facebook"><i class="fa fa-facebook"/></a>
                                <a href="https://www.instagram.com/techriseae" target="_blank" rel="noopener" aria-label="Instagram"><i class="fa fa-instagram"/></a>
                            </div>
                        </div>

                        <!-- Quick Links -->
                        <div class="col-lg-2 col-md-6 mb-4">
                            <h5>Quick Links</h5>
                            <ul class="tr-footer-links">
                                <li><a href="/">Home</a></li>
                                <li><a href="/about">About Us</a></li>
                                <li><a href="/services">Services</a></li>
                                <li><a href="/server">Server &amp; Hosting</a></li>
                                <li><a href="/contactus">Contact</a></li>
                            </ul>
                        </div>

                        <!-- Services -->
                        <div class="col-lg-3 col-md-6 mb-4">
                            <h5>Our Services</h5>
                            <ul class="tr-footer-links">
                                <li><a href="/services#erp">ERP Systems (Odoo)</a></li>
                                <li><a href="/services#website">Website Development</a></li>
                                <li><a href="/services#mobile">Mobile Apps</a></li>
                                <li><a href="/services#integration">System Integration</a></li>
                                <li><a href="/services#accounting">Accounting &amp; Tax</a></li>
                                <li><a href="/services#branding">Branding &amp; Marketing</a></li>
                            </ul>
                        </div>

                        <!-- Contact Info -->
                        <div class="col-lg-3 col-md-6 mb-4">
                            <h5>Contact Us</h5>
                            <div class="tr-footer-contact-item">
                                <i class="fa fa-map-marker"/>
                                <span>Abu Dhabi, Al Bateen Commercial Tower</span>
                            </div>
                            <div class="tr-footer-contact-item">
                                <i class="fa fa-phone"/>
                                <a href="tel:+971585955064" style="color: inherit; text-decoration: none;">+971 58 595 5064</a>
                            </div>
                            <div class="tr-footer-contact-item">
                                <i class="fa fa-phone"/>
                                <a href="tel:+971585755064" style="color: inherit; text-decoration: none;">+971 58 575 5064</a>
                            </div>
                            <div class="tr-footer-contact-item">
                                <i class="fa fa-envelope"/>
                                <span>info@techriseae.com</span>
                            </div>
                            <div class="tr-footer-contact-item">
                                <i class="fa fa-clock-o"/>
                                <span>Available 24/7</span>
                            </div>
                        </div>
                    </div>

                    <!-- Footer Bottom -->
                    <div class="tr-footer-bottom">
                        <p class="mb-0">
                            Techrise - Your Partner in Organized Digital Transformation.
                            All rights reserved. |
                            <a href="/privacy-policy" style="color: inherit;">Privacy Policy</a> |
                            <a href="/terms-and-conditions" style="color: inherit;">Terms &amp; Conditions</a>
                        </p>
                    </div>
                </div>
            </div>
        </xpath>
    </template>

</odoo>
