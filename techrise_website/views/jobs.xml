<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- JOBS PAGE - Hero Banner                                       -->
    <!-- ============================================================ -->
    <template id="jobs_hero_banner" inherit_id="website_hr_recruitment.index" name="Techrise Jobs Hero">
        <xpath expr="//div[@id='wrap']" position="before">
            <section class="tr-page-header tr-header-jobs">
                <div class="container">
                    <h1>Join Our <span class="tr-text-gold">Team</span></h1>
                    <p>Be part of a team that's transforming businesses through technology</p>
                    <div class="tr-breadcrumb">
                        <a href="/">Home</a>
                        <span> / </span>
                        <span class="active">Careers</span>
                    </div>
                </div>
            </section>
        </xpath>

        <!-- Add custom class to wrap div -->
        <xpath expr="//div[@id='wrap']" position="attributes">
            <attribute name="class" add="tr-jobs-wrap" separator=" "/>
        </xpath>

        <!-- Replace "Our Job Offers" brand text -->
        <xpath expr="//span[hasclass('navbar-brand')]" position="replace">
            <span class="navbar-brand h5 my-0 me-sm-auto" style="color: #0D1B3E; font-weight: 700;">
                Open Positions
            </span>
        </xpath>
    </template>

    <!-- ============================================================ -->
    <!-- JOB DETAIL - Add missing schema.org JobPosting fields         -->
    <!-- Fixes: description (critical), baseSalary, validThrough       -->
    <!-- ============================================================ -->
    <template id="job_detail_schema_fix" inherit_id="website_hr_recruitment.detail" name="Techrise Job Schema Fix">
        <!-- Add itemprop="description" to the website_description div -->
        <xpath expr="//div[@t-field='job.website_description']" position="attributes">
            <attribute name="itemprop">description</attribute>
        </xpath>

        <!-- Add baseSalary and validThrough meta tags inside JobPosting itemscope -->
        <xpath expr="//div[@itemtype='https://schema.org/JobPosting']/meta[@itemprop='directApply']" position="after">
            <!-- Valid through: 90 days from posting date -->
            <meta t-if="job.published_date" itemprop="validThrough"
                  t-att-content="(job.published_date + datetime.timedelta(days=90)).isoformat()"/>

            <!-- Base Salary Schema -->
            <span itemprop="baseSalary" itemscope="itemscope" itemtype="https://schema.org/MonetaryAmount">
                <meta itemprop="currency" content="AED"/>
                <span itemprop="value" itemscope="itemscope" itemtype="https://schema.org/QuantitativeValue">
                    <meta itemprop="unitText" content="MONTH"/>
                    <meta itemprop="minValue" content="5000"/>
                    <meta itemprop="maxValue" content="15000"/>
                </span>
            </span>

            <!-- Industry -->
            <meta itemprop="industry" content="Information Technology"/>
        </xpath>
    </template>

    <!-- ============================================================ -->
    <!-- JOBS PAGE - Replace Right Sidebar with Techrise Info          -->
    <!-- ============================================================ -->
    <template id="jobs_custom_sidebar" inherit_id="website_hr_recruitment.job_right_side_bar" name="Techrise Jobs Sidebar">
        <xpath expr="//div[@id='jobs_grid_right']" position="replace">
            <div class="col-lg-4" id="jobs_grid_right">
                <section class="tr-jobs-sidebar">
                    <div class="tr-sidebar-card">
                        <img src="/techrise_website/static/src/img/logo.png"
                             class="tr-sidebar-logo"
                             alt="Techrise"/>
                        <p class="tr-sidebar-intro">
                            Techrise is your trusted partner for organized digital transformation.
                            We help businesses grow through smart technology solutions.
                        </p>
                        <hr class="tr-sidebar-divider"/>
                        <h5 class="tr-sidebar-title">Get in Touch</h5>
                        <ul class="tr-sidebar-contact">
                            <li>
                                <i class="fa fa-comment"/>
                                <a href="/contactus">Contact Us</a>
                            </li>
                            <li>
                                <i class="fa fa-envelope"/>
                                <a href="mailto:info@techriseae.com">info@techriseae.com</a>
                            </li>
                            <li>
                                <i class="fa fa-phone"/>
                                <a href="tel:+971585955064" class="o_force_ltr">+971 58 595 5064</a>
                            </li>
                            <li>
                                <i class="fa fa-phone"/>
                                <a href="tel:+971585755064" class="o_force_ltr">+971 58 575 5064</a>
                            </li>
                            <li>
                                <i class="fa fa-map-marker"/>
                                <span>Abu Dhabi, UAE</span>
                            </li>
                        </ul>
                        <hr class="tr-sidebar-divider"/>
                        <h5 class="tr-sidebar-title">Follow Us</h5>
                        <div class="tr-sidebar-social">
                            <a href="#" aria-label="LinkedIn"><i class="fa fa-linkedin"/></a>
                            <a href="#" aria-label="Twitter"><i class="fa fa-twitter"/></a>
                            <a href="#" aria-label="Facebook"><i class="fa fa-facebook"/></a>
                            <a href="#" aria-label="Instagram"><i class="fa fa-instagram"/></a>
                        </div>
                    </div>
                </section>
            </div>
        </xpath>
    </template>

</odoo>
