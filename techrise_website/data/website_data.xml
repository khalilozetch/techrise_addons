<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

        <!-- Website Menu Items -->
        <record id="menu_home" model="website.menu">
            <field name="name">Home</field>
            <field name="url">/</field>
            <field name="parent_id" ref="website.main_menu"/>
            <field name="sequence">10</field>
            <field name="website_id" ref="website.default_website"/>
        </record>

        <record id="menu_about" model="website.menu">
            <field name="name">About Us</field>
            <field name="url">/about</field>
            <field name="parent_id" ref="website.main_menu"/>
            <field name="sequence">20</field>
            <field name="website_id" ref="website.default_website"/>
        </record>

        <record id="menu_services" model="website.menu">
            <field name="name">Services</field>
            <field name="url">/services</field>
            <field name="parent_id" ref="website.main_menu"/>
            <field name="sequence">30</field>
            <field name="website_id" ref="website.default_website"/>
        </record>

        <!-- Solutions dropdown (product-focused landing pages).
             Distinct from Services: Services = what Techrise does,
             Solutions = which software product is being sold.
             Parent menu has no url so it renders as a pure dropdown. -->
        <record id="menu_solutions" model="website.menu">
            <field name="name">Solutions</field>
            <field name="url">#</field>
            <field name="parent_id" ref="website.main_menu"/>
            <field name="sequence">35</field>
            <field name="website_id" ref="website.default_website"/>
        </record>

        <record id="menu_solutions_accounting" model="website.menu">
            <field name="name">Accounting Software</field>
            <field name="url">/accounting-software-uae</field>
            <field name="parent_id" ref="menu_solutions"/>
            <field name="sequence">10</field>
            <field name="website_id" ref="website.default_website"/>
        </record>

        <record id="menu_server" model="website.menu">
            <field name="name">Server &amp; Hosting</field>
            <field name="url">/server</field>
            <field name="parent_id" ref="website.main_menu"/>
            <field name="sequence">40</field>
            <field name="website_id" ref="website.default_website"/>
        </record>

        <record id="menu_contact" model="website.menu">
            <field name="name">Contact Us</field>
            <field name="url">/contactus</field>
            <field name="parent_id" ref="website.main_menu"/>
            <field name="sequence">50</field>
            <field name="website_id" ref="website.default_website"/>
        </record>

    </data>

    <!-- Set website logo (runs on every update) -->
    <data noupdate="0">
        <record id="website.default_website" model="website">
            <field name="logo" type="base64" file="techrise_website/static/src/img/logo.png"/>
        </record>
    </data>
</odoo>
